[{{ name }}]
# --- Identity ---
{% if description %}
description = "{{ description }}"
{% endif %}
{% if provider %}
provider = "{{ provider }}"
{% endif %}

# --- Connectivity ---
uri = "{{ uri }}"
model_name = "{{ model_name }}"

# --- Security ---
# 'api_key_env' (Environment Variable) takes precedence over 'api_key' (Direct String).
{% if api_key %}
api_key = "{{ api_key }}"
{% endif %}
{% if api_key_env %}
api_key_env = "{{ api_key_env }}"
{% endif %}

# --- Inference Defaults ---
max_context = {{ max_context }}
temperature = {{ temperature }}
top_p = {{ top_p }}
top_k = {{ top_k }}
repetition_penalty = {{ repetition_penalty }}
